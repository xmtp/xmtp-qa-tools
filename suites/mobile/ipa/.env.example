# XMTP QA Tools - IPA Testing Environment Variables

# Required for all operations
XMTP_ENV=dev                    # Options: local, dev, production
LOGGING_LEVEL=off               # Options: off, debug, info, warn, error

# IPA Testing Specific
IPA_PATH=/path/to/your/app.ipa  # Path to your React Native app IPA file
APP_BUNDLE_ID=com.example.app   # Your app's bundle identifier

# Device Configuration (Optional)
IOS_SIMULATOR_UDID=             # Specific simulator UDID to use
IOS_DEVICE_UDID=                # Specific physical device UDID to use
DEVICE_TYPE=iPhone 15 Pro       # Preferred device type for new simulators

# Maestro Configuration (Optional)
MAESTRO_DEBUG=true              # Enable debug logging
VIDEO_RECORDING=false           # Enable video recording of tests
SCREENSHOT_ON_FAILURE=true      # Take screenshots on test failures

# Optional - for Slack notifications and monitoring
SLACK_BOT_TOKEN=xoxb-...        # Slack bot token for notifications
SLACK_CHANNEL=C...              # Slack channel ID for alerts
DATADOG_API_KEY=...             # Datadog API key for metrics

# Optional - for geolocation testing
GEOLOCATION=us-east-1           # AWS region for testing

# Test Configuration
KEEP_APP_RUNNING=false          # Keep app running after tests complete
CLEANUP_SIMULATORS=true         # Clean up test simulators after tests